rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Only the user themselves can read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Anyone authenticated can read ACTIVE listings. Only owners can write.
    match /listings/{listingId} {
      allow read: if request.auth != null && resource.data.status == "active";
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }
    
    // NO client access to private listing data. Handled via Cloud Functions/Admin SDK.
    match /listing_private/{listingId} {
      allow read, write: if false; 
    }
    
    // NO client access to enquiries. Handled via Cloud Functions.
    match /enquiries/{enquiryId} {
      allow read, write: if false;
    }
  }
}
